				<textFieldExpression><![CDATA["     Bahwa yang bersangkutan dalam keadaan hamil "+$F{keterangan_hamil}+" dengan Hari Pertama Haid Terakhir (HPHT) pada tanggal "+new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id")).format($F{perkiraan_lahir})+" dan Taksiran Persalinan (TP) pada tanggal "+ new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id")).format($F{perkiraan_lahir}.getTime() + (280L * 24 * 60 * 60 * 1000))+". Mohon untuk diberikan cuti melahirkan dari tanggal "+new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id")).format($F{terhitung_mulai})+" s.d "+new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id")).format($F{selesai_cuti})+"."]]></textFieldExpression>
